# Server
PORT=3000
HOST=0.0.0.0

# ScyllaDB connection
SCYLLA_HOST=scylla
SCYLLA_PORT=9042
SCYLLA_DATACENTER=datacenter1
SCYLLA_KEYSPACE=cc_fleet
SCYLLA_USERNAME=
SCYLLA_PASSWORD=

# Auth (required)
JWT_SECRET=change-me-to-a-random-string

# GitHub OAuth (required)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_SCOPES=read:user,repo

# Optional: GitHub token for server-side git operations
GIT_TOKEN=

# Optional: Anthropic API key for Claude agent tasks
ANTHROPIC_API_KEY=

# Task execution
MAX_CONCURRENT_TASKS=5
WORKSPACE_BASE_DIR=/tmp/cc-fleet-workspaces

# Comma-separated glob patterns for allowed repos (empty = allow all)
ALLOWED_REPOS=

# CORS origin for the web UI
CORS_ORIGIN=http://localhost:5173

# Auth mode: "apiKey" or "subscription"
AUTH_MODE=apiKey
